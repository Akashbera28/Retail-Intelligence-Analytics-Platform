# Retail Analytics - .gitignore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/

# --- Node / Frontend ---
node_modules/
frontend/node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
dist/

# --- Environment Variables ---
.env
.env.local
.env.*.local

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Database ---
*.sqlite
*.sqlite3
*.db

# --- Datasets (large files) ---
datasets/*.csv
datasets/*.json
datasets/*.parquet
datasets/*.pkl

# --- Logs ---
*.log
logs/

# --- OS ---
Thumbs.db
Desktop.ini

# --- Docker ---
docker-compose.override.yml

